{
  "name": "@prostojs/infact",
  "version": "0.3.6",
  "description": "Instance Factory and Instance Registry for Metadata based Dependency Injection scenarios",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "index.js",
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "release": "node ./scripts/release.js",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "lint": "eslint --ext .ts src/**.ts --fix",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "version": "conventional-changelog -p angular -i CHANGELOG.md -s && git add CHANGELOG.md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prostojs/infact.git"
  },
  "keywords": [
    "infact",
    "instance factory",
    "dependency injection",
    "prostojs"
  ],
  "buildOptions": {
    "name": "ProstoInfact",
    "formats": [
      "esm-bundler",
      "cjs"
    ]
  },
  "gitHooks": {
    "commit-msg": "node scripts/verifyCommit.js"
  },
  "author": "Artem Maltsev",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/prostojs/infact/issues"
  },
  "homepage": "https://github.com/prostojs/infact#readme",
  "devDependencies": {
    "@prostojs/dye": "^0.3.0",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@types/node": "^22.19.11",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "@vitest/coverage-v8": "^4.0.18",
    "conventional-changelog": "^3.1.25",
    "conventional-changelog-cli": "^2.2.2",
    "enquirer": "^2.4.1",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-import": "^2.32.0",
    "execa": "^5.1.1",
    "fs-extra": "^10.1.0",
    "minimist": "^1.2.8",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "semver": "^7.7.4",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "yorkie": "^2.0.0"
  }
}
