{
    "name": "@prostojs/infact",
    "version": "0.4.0",
    "description": "Instance Factory and Instance Registry for Metadata based Dependency Injection scenarios",
    "keywords": [
        "dependency injection",
        "infact",
        "instance factory",
        "prostojs"
    ],
    "homepage": "https://github.com/prostojs/infact#readme",
    "bugs": {
        "url": "https://github.com/prostojs/infact/issues"
    },
    "license": "MIT",
    "author": "Artem Maltsev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/prostojs/infact.git"
    },
    "files": [
        "index.js",
        "dist"
    ],
    "sideEffects": false,
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json && rolldown -c rolldown.config.mjs && rm -rf dts-build",
        "release": "node ./scripts/release.js",
        "test": "vitest run",
        "test:cov": "vitest run --coverage",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
        "version": "conventional-changelog -p angular -i CHANGELOG.md -s && git add CHANGELOG.md"
    },
    "devDependencies": {
        "@prostojs/dye": "^0.4.9",
        "@types/node": "^22.19.11",
        "@vitest/coverage-v8": "^4.0.18",
        "conventional-changelog": "^3.1.25",
        "conventional-changelog-cli": "^2.2.2",
        "enquirer": "^2.4.1",
        "execa": "^5.1.1",
        "fs-extra": "^10.1.0",
        "minimist": "^1.2.8",
        "oxfmt": "^0.35.0",
        "oxlint": "^1.50.0",
        "rolldown": "1.0.0-rc.5",
        "rolldown-plugin-dts": "^0.22.1",
        "semver": "^7.7.4",
        "ts-node": "^10.9.2",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18",
        "yorkie": "^2.0.0"
    },
    "buildOptions": {
        "name": "ProstoInfact",
        "formats": [
            "esm-bundler",
            "cjs"
        ]
    },
    "gitHooks": {
        "commit-msg": "node scripts/verifyCommit.js"
    }
}
